{
  "name": "fastfoodfunkin",
  "version": "1.0.0",
  "description": "electron-app ruffle-wrapper swf",
  "keywords": [
    "swf",
    "ruffle",
    "rhythm",
    "flashforwardjam",
    "flash",
    "jam"
  ],
  "homepage": "https://github.com/BrandyBuizel/flashforwardjam#readme",
  "bugs": {
    "url": "https://github.com/BrandyBuizel/flashforwardjam/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrandyBuizel/flashforwardjam.git"
  },
  "license": "Apache-2.0",
  "author": "Milktoast Stuff",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build-icons": "mkdir -p icons && icon-gen -i icon.png -o icons",
    "build:mac": "bun run build-icons && electron-builder --mac --universal -c.mac.identity=null --publish never",
    "build:win": "bun run build-icons && electron-builder --win",
    "build:linux": "bun run build-icons && electron-builder --linux"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^41.2.0",
    "@types/bun": "latest",
    "icon-gen": "latest"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
